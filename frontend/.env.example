# SvelteKit self-hosted frontend.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# Controller endpoint — usually the controller's agent port on localhost or
# the docker-compose service name.
HOISTER_CONTROLLER_URL=http://localhost:3033

# Basic-auth credentials for the frontend's login page.
# HOISTER_AUTH_PASSWORD may be plaintext or a bcrypt hash.
HOISTER_AUTH_USERNAME=admin
HOISTER_AUTH_PASSWORD=replace-me

# Optional cookie/TLS hardening (defaults shown).
# USE_HTTPS=false
# USE_SECURE_COOKIES=false
# SESSION_MAX_AGE=604800
# COOKIE_SAME_SITE=strict
