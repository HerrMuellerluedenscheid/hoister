# SvelteKit cloud frontend (BFF for the hosted controller).
# Copy to `.env` and fill in real values. `.env` is gitignored.

# Clerk authentication keys — get from https://dashboard.clerk.com
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me

# Controller internal endpoint. The frontend talks to the controller over the
# private network on its internal port (3034). Never set this to a public URL.
HOISTER_CONTROLLER_URL=http://127.0.0.1:3034
